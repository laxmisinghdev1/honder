# ------------------------------------------------------------
# APP / DEPLOY
# ------------------------------------------------------------
VITE_APP_ENV=development
VITE_PUBLIC_SITE_URL=http://localhost:5173

# ------------------------------------------------------------
# SUPABASE
# Optional for this frontend handoff.
# Leave empty unless you wire Supabase back in.
# ------------------------------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_SCHEMA=public
VITE_SUPABASE_CONTACT_TABLE=hondar_contact_inquiries
VITE_SUPABASE_ORDER_TABLE=hondar_orders
VITE_SUPABASE_REVIEW_TABLE=hondar_product_reviews
VITE_SUPABASE_CHAT_TABLE=hondar_chat_messages

# ------------------------------------------------------------
# CONTACT / CHECKOUT
# Leave blank to run frontend-only fallbacks in local dev.
# ------------------------------------------------------------
VITE_CONTACT_API_URL=
VITE_CHECKOUT_API_URL=

# ------------------------------------------------------------
# CHATBOT
# Leave VITE_CHAT_API_URL blank to use /api/chat when available.
# The server endpoint already falls back if OPENAI_API_KEY is missing.
# ------------------------------------------------------------
VITE_CHAT_API_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHATBOT_SYSTEM_PROMPT=You are the HONDAR shopping assistant. Help users with products, sizes, payments, shipping, and purchase recommendations.
CHATBOT_MAX_HISTORY=10

# ------------------------------------------------------------
# PAYMENTS
# Leave empty for demo/mock checkout in local development.
# ------------------------------------------------------------
VITE_MERCADO_PAGO_ENV=sandbox
VITE_MERCADO_PAGO_PUBLIC_KEY=
MP_PUBLIC_KEY=
MP_ACCESS_TOKEN=

VITE_GETNET_ENV=sandbox
GETNET_BASE_URL=
GETNET_LOGIN=
GETNET_SECRET_KEY=
GETNET_PAYMENT_LINK=

# ------------------------------------------------------------
# OPTIONAL EMAIL / NOTIFICATIONS
# ------------------------------------------------------------
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=
NOTIFICATION_TO_EMAIL=
